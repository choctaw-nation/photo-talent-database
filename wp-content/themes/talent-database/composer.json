{
	"name": "choctaw-nation/talent-database-theme",
	"description": "a template theme to fork",
	"type": "project",
	"version": "1.11.2",
	"repositories": [
		{
			"type": "composer",
			"url": "https://wpackagist.org",
			"only": [
				"wpackagist-plugin/*",
				"wpackagist-theme/*"
			]
		}
	],
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"scripts": {
		"phpcs": "phpcs . inc/ --extensions=php",
		"phpcbf": "phpcbf . inc/ --extensions=php"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "*"
	}
}
